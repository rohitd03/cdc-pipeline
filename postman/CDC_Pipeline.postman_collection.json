				{
					"name": "Search with Sort",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/search/orders?sort_by=amount&sort_order=asc",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "search", "orders"],
							"query": [
								{
									"key": "sort_by",
									"value": "amount"
								},
								{
									"key": "sort_order",
									"value": "asc"
								}
							]
						},
						"description": "Sort orders by amount ascending"
					},
					"response": []
				},
				{
					"name": "Get Single Order from ES",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/search/orders/{{order_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "search", "orders", "{{order_id}}"]
						},
						"description": "Get a single order directly from Elasticsearch"
					},
					"response": []
				}
			],
			"description": "Search operations (read from Elasticsearch)"
		},
