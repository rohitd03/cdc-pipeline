{
	"info": {
		"_postman_id": "cdc-pipeline-collection",
		"name": "CDC Pipeline API",
		"description": "Complete API collection for CDC Pipeline project",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Orders (Write)",
			"item": [
				{
					"name": "Create Order",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const responseJson = pm.response.json();",
									"    pm.environment.set('order_id', responseJson.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"customer_id\": \"{{customer_id}}\",\n  \"customer_name\": \"John Doe\",\n  \"customer_email\": \"john.doe@example.com\",\n  \"product_name\": \"Wireless Headphones\",\n  \"product_sku\": \"WH-1000X\",\n  \"quantity\": 1,\n  \"amount\": 299.99,\n  \"currency\": \"USD\",\n  \"shipping_address\": \"123 Main St, New York, NY 10001\",\n  \"notes\": \"Please deliver before 5 PM\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/orders",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "orders"]
						},
						"description": "Create a new order in PostgreSQL"
					},
					"response": []
				},
				{
					"name": "Update Order Status - Confirm",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"confirmed\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/orders/{{order_id}}/status",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "orders", "{{order_id}}", "status"]
						},
						"description": "Update order status to confirmed"
					},
					"response": []
				},
				{
					"name": "Update Order Status - Ship",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"shipped\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/orders/{{order_id}}/status",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "orders", "{{order_id}}", "status"]
						},
						"description": "Update order status to shipped"
					},
					"response": []
				},
				{
					"name": "Update Order Status - Invalid Transition",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"pending\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/orders/{{order_id}}/status",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "orders", "{{order_id}}", "status"]
						},
						"description": "Attempt an invalid status transition (should return 409)"
					},
					"response": []
				},
				{
					"name": "Get Order by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/orders/{{order_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "orders", "{{order_id}}"]
						},
						"description": "Get a single order from PostgreSQL by ID"
					},
					"response": []
				},
				{
					"name": "Delete Order",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/orders/{{order_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "orders", "{{order_id}}"]
						},
						"description": "Delete an order from PostgreSQL"
					},
					"response": []
				}
			],
			"description": "Order management endpoints (write operations using PostgreSQL)"
		},
