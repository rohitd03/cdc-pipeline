							"query": [
								{
									"key": "customer_id",
									"value": "{{customer_id}}"
								}
							]
						},
						"description": "Filter orders by customer ID"
					},
					"response": []
				},
				{
					"name": "Search with Pagination",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/search/orders?page=2&page_size=5",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "search", "orders"],
							"query": [
								{
									"key": "page",
									"value": "2"
								},
								{
									"key": "page_size",
									"value": "5"
								}
							]
						},
						"description": "Paginated search results"
					},
					"response": []
