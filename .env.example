# Server
SERVER_PORT=8080

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=orders_db
POSTGRES_SSL_MODE=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=2

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=cdc-pipeline-consumer
KAFKA_TOPIC=postgres.public.orders
KAFKA_DLQ_TOPIC=postgres.public.orders.dlq
KAFKA_MAX_RETRIES=3
KAFKA_RETRY_BASE_MS=100

# Elasticsearch
ES_ADDRESSES=http://localhost:9200
ES_USERNAME=
ES_PASSWORD=
ES_INDEX_NAME=orders

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
